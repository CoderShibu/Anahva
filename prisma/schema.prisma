// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Using PostgreSQL for Supabase production database
}

// Session management
model Session {
  id            String   @id @default(uuid())
  session_id    String   @unique
  language      String   @default("EN") // EN or HI
  demo          Boolean  @default(false)
  created_at    DateTime @default(now())
  last_active   DateTime @default(now())
  expires_at    DateTime
  is_active     Boolean  @default(true)
  
  // Relations
  journals      Journal[]
  memories      Memory[]
  chat_sessions ChatSession[]
  insights      Insight[]
  safety_events SafetyEvent[]
  
  @@index([session_id])
  @@index([expires_at])
  @@map("sessions")
}

// Journal entries - encrypted storage only
model Journal {
  id               String   @id @default(uuid())
  session_id       String
  encrypted_payload String  // Base64 encoded encrypted data
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  allow_ai_memory  Boolean  @default(false)
  deleted_at       DateTime? // Soft delete for audit
  
  session          Session  @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  
  @@index([session_id])
  @@index([created_at])
  @@map("journals")
}

// AI Memory - embeddings only, no raw text
model Memory {
  id              String   @id @default(uuid())
  session_id      String
  embedding_vector String  // Vector embedding array (JSON string)
  memory_type     String   // "journal", "chat", "insight"
  created_at      DateTime @default(now())
  expires_at      DateTime? // Memory expiry after inactivity
  
  session         Session  @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  
  @@index([session_id])
  @@index([expires_at])
  @@map("memories")
}

// Chat sessions - metadata only, no content stored
model ChatSession {
  id              String   @id @default(uuid())
  session_id      String
  mode            String   @default("LISTEN") // LISTEN, REFLECT, CALM
  created_at      DateTime @default(now())
  last_message_at DateTime @default(now())
  
  session         Session  @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  
  @@index([session_id])
  @@map("chat_sessions")
}

// Insights - aggregated metadata only
model Insight {
  id              String   @id @default(uuid())
  session_id      String
  insight_type    String   // "pattern", "trend", "narrative"
  metadata        String   // Aggregated data only (JSON string)
  created_at      DateTime @default(now())
  
  session         Session  @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  
  @@index([session_id])
  @@index([created_at])
  @@map("insights")
}

// Safety events - consent and flags only
model SafetyEvent {
  id              String   @id @default(uuid())
  session_id      String
  event_type      String   // "grounding", "external_help", "emergency_consent"
  consent_given   Boolean
  consent_at      DateTime?
  flags           String?  // Safety flags only (JSON string)
  created_at      DateTime @default(now())
  
  session         Session  @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  
  @@index([session_id])
  @@index([created_at])
  @@map("safety_events")
}

// Audit log - system events only, no user content
model AuditLog {
  id              String   @id @default(uuid())
  session_id      String?
  event_type      String   // "login", "logout", "data_purge", "memory_forget"
  action          String
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())
  
  @@index([session_id])
  @@index([created_at])
  @@index([event_type])
  @@map("audit_logs")
}

